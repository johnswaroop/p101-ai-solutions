{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "p101-mcp",
      "version": "0.1.0",
      "title": "P101 Limited MCP"
    },
    "tools": [
      {
        "name": "get_company_info",
        "title": "Get company info",
        "description": "Return an overview of P101 Limited: what the company does, its ventures (DcernX, Xylor), consulting practice, and office locations.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_services",
        "title": "List P101 services",
        "description": "List P101's consulting disciplines and custom-software capabilities. Optionally filter by discipline id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "discipline": {
              "description": "Optional discipline id to filter by.",
              "type": "string",
              "enum": [
                "agentic",
                "generative",
                "vision",
                "predictive",
                "custom-software"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_contact_details",
        "title": "Get P101 contact details",
        "description": "Return P101's contact email and office addresses (USA and UK), plus a mailto link for booking a discovery call.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
